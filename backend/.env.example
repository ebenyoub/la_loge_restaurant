NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
CORS_ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=info

# MySQL / Prisma — remplacer uniquement dans un environnement local ou géré.
DATABASE_URL=mysql://DATABASE_USER:DATABASE_PASSWORD@DATABASE_HOST:3306/DATABASE_NAME

# Authentification et e-mail — à renseigner après validation des prérequis.
SESSION_SECRET=
JWT_SECRET=
JWT_EXPIRES_IN=8h
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM=
RESTAURANT_NOTIFICATION_EMAIL=
